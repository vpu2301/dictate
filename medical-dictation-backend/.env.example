# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit real credentials.

# ── PostgreSQL ───────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=medical_dictation

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── MinIO (S3-compatible) ────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=http://localhost:9000

# ── Kafka ────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ── Keycloak ─────────────────────────────────────────────────
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_REALM=medical-dictation
KEYCLOAK_CLIENT_ID=backend-api
KEYCLOAK_CLIENT_SECRET=dev-secret-change-in-prod

# ── OpenTelemetry ────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=template-service

# ── Dev flags ────────────────────────────────────────────────
# WARNING: disables auth enforcement in dev only — never set in staging/prod
AUTH_BYPASS_DEV=false
LOG_LEVEL=INFO
ENVIRONMENT=development
