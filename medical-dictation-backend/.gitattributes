# Force LF line endings everywhere; no CRLF on Windows checkouts.
* text=auto eol=lf

*.py    text eol=lf
*.toml  text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.sh    text eol=lf
Makefile text eol=lf

# Binary
*.png   binary
*.jpg   binary
*.gz    binary
