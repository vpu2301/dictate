# Copy to .env.local. Never commit .env.local.
ENVIRONMENT=development
LOG_LEVEL=INFO

AUTH_ISSUER=http://localhost:8088/realms/medical-dictation
AUTH_JWKS_URL=http://localhost:8088/realms/medical-dictation/protocol/openid-connect/certs
AUTH_AUDIENCE=mdx-api

DB_APP_ROLE_DSN=postgresql://app_role:app_role@localhost:5432/medical_dictation
DB_AUDIT_WRITER_DSN=postgresql://audit_writer:audit_writer@localhost:5432/medical_dictation

REDIS_URL=redis://localhost:6379/0
MDX_NLP_CACHE_TTL_SECONDS=3600
MDX_NLP_CACHE_KEY_PREFIX=mdx:nlp:cache

MDX_NLP_MAX_INPUT_BYTES=8192
MDX_NLP_MAX_INPUT_WORDS=1000

MDX_NLP_RATE_LIMIT_PER_TENANT_RPS=1000
MDX_NLP_RATE_LIMIT_PER_IP_RPS=50

# Punctuation
# In the pinned image this is the BAKED local dir (/opt/models/punctuation),
# loaded fully offline. A bare HF id only resolves with network access.
MDX_NLP_PUNCTUATION_MODEL=oliverguhr/fullstop-punctuation-multilang-large
MDX_NLP_PUNCTUATION_TIMEOUT_MS=250
MDX_NLP_PUNCTUATION_TOKEN_BUDGET=256
MDX_NLP_PUNCTUATION_DISABLED=false
# Build-time provenance (Sprint B1 Day 2, ADR-0021).
MDX_NLP_PUNCTUATION_MODEL_REPO=oliverguhr/fullstop-punctuation-multilang-large
MDX_NLP_PUNCTUATION_MODEL_REVISION=345e80adc07e761d3a35feafd20f2f44a151f453
MDX_NLP_PUNCTUATION_MODEL_SHA256=270f27d7398a5fdad43bdf9953ea532fbe62c5f5227ed5f5316e9bd64a9255e1
HF_HUB_OFFLINE=1
TRANSFORMERS_OFFLINE=1

MDX_NLP_ABBREV_CACHE_TTL_SECONDS=60
MDX_NLP_CONFIDENCE_HIGH_CONCERN_BELOW=0.40
MDX_NLP_CONFIDENCE_MODERATE_BELOW=0.65
