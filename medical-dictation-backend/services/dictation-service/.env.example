# Copy to .env.local and adjust. Never commit .env.local.
ENVIRONMENT=development
LOG_LEVEL=INFO

AUTH_ISSUER=http://localhost:8088/realms/medical-dictation
AUTH_JWKS_URL=http://localhost:8088/realms/medical-dictation/protocol/openid-connect/certs
AUTH_AUDIENCE=mdx-api

DB_APP_ROLE_DSN=postgresql://app_role:app_role@localhost:5432/medical_dictation
DB_AUDIT_WRITER_DSN=postgresql://audit_writer:audit_writer@localhost:5432/medical_dictation
DB_CRYPTO_WRITER_DSN=postgresql://crypto_writer:crypto_writer@localhost:5432/medical_dictation

REDIS_URL=redis://localhost:6379/0

S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_AUDIO_BUCKET=mdx-audio

MDX_MASTER_KEY_PATH=/etc/mdx/master.key
MDX_TMPFS_ROOT=/run/dictation
MDX_WORKER_ID=worker-dev-1

# Streaming protocol
MDX_WS_SUBPROTOCOL=medical-dictation.v1
MDX_WS_HEARTBEAT_INTERVAL_S=10
MDX_WS_IDLE_TIMEOUT_S=35
MDX_WS_MAX_BINARY_FRAME_BYTES=8192

MDX_PER_WORKER_MAX_SESSIONS=4
MDX_PER_TENANT_MAX_ACTIVE_SESSIONS=10

# Windowing
MDX_WINDOW_SECONDS=4.0
MDX_WINDOW_OVERLAP_SECONDS=2.0
MDX_WINDOW_MIN_FOR_PARTIAL_SECONDS=1.5
MDX_WINDOW_TICK_INTERVAL_MS=600

# Whisper engine (in-process)
MD_ASR_DEVICE=cpu
MD_ASR_MODEL=tiny
MD_ASR_COMPUTE_TYPE=int8
MD_ASR_BEAM_SIZE=5
