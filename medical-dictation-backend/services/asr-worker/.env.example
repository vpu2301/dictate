# Copy to .env.local and adjust. Never commit .env.local.
ENVIRONMENT=development
LOG_LEVEL=INFO

# Set to `cuda` only if NVIDIA Container Toolkit is configured.
MD_ASR_DEVICE=cpu
# In the pinned images this is the BAKED local dir, not a HF id:
#   GPU image: /opt/models/whisper-large-v3   CPU image: /opt/models/whisper-tiny
# A bare id like "tiny"/"large-v3" only works with network access (dev outside
# Docker). Inside the offline images, always point at the baked dir.
MD_ASR_MODEL=tiny
MD_ASR_COMPUTE_TYPE=int8
MD_ASR_BEAM_SIZE=5

# ── Model sourcing / pinning (Sprint B1 Day 1, ADR-0021) ───────────────
# Build-time provenance. Defaults are a no-op at runtime (MD_ASR_MODEL above
# selects the weights); these just let the worker log which pinned
# repo@revision produced the baked image, and reject an unknown engine.
MD_ASR_ENGINE=faster_whisper
MD_ASR_MODEL_REPO=Systran/faster-whisper-large-v3
MD_ASR_MODEL_REVISION=edaa852ec7e145841d8ffdb056a99866b5f0a478
MD_ASR_MODEL_SHA256=69f74147e3334731bc3a76048724833325d2ec74642fb52620eda87352e3d4f1
# Offline runtime (set in the image; shown here for clarity).
HF_HUB_OFFLINE=1
TRANSFORMERS_OFFLINE=1

DB_APP_ROLE_DSN=postgresql://app_role:app_role@localhost:5432/medical_dictation
DB_AUDIT_WRITER_DSN=postgresql://audit_writer:audit_writer@localhost:5432/medical_dictation
DB_CRYPTO_WRITER_DSN=postgresql://crypto_writer:crypto_writer@localhost:5432/medical_dictation

REDIS_URL=redis://localhost:6379/0
MD_ASR_JOBS_STREAM=asr:jobs
MD_ASR_JOBS_DLQ_STREAM=asr:jobs:dlq
MD_ASR_JOBS_GROUP=asr-workers
MD_ASR_WORKER_NAME=worker-dev

S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_AUDIO_BUCKET=mdx-audio
S3_TRANSCRIPTS_BUCKET=mdx-transcripts

MDX_MASTER_KEY_PATH=/etc/mdx/master.key
