# Copy to .env.local and adjust. Never commit .env.local.
ENVIRONMENT=development
LOG_LEVEL=INFO

# Set to `cuda` only if NVIDIA Container Toolkit is configured.
MD_ASR_DEVICE=cpu
MD_ASR_MODEL=tiny
MD_ASR_COMPUTE_TYPE=int8
MD_ASR_BEAM_SIZE=5

DB_APP_ROLE_DSN=postgresql://app_role:app_role@localhost:5432/medical_dictation
DB_AUDIT_WRITER_DSN=postgresql://audit_writer:audit_writer@localhost:5432/medical_dictation
DB_CRYPTO_WRITER_DSN=postgresql://crypto_writer:crypto_writer@localhost:5432/medical_dictation

REDIS_URL=redis://localhost:6379/0
MD_ASR_JOBS_STREAM=asr:jobs
MD_ASR_JOBS_DLQ_STREAM=asr:jobs:dlq
MD_ASR_JOBS_GROUP=asr-workers
MD_ASR_WORKER_NAME=worker-dev

S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_AUDIO_BUCKET=mdx-audio
S3_TRANSCRIPTS_BUCKET=mdx-transcripts

MDX_MASTER_KEY_PATH=/etc/mdx/master.key
