# core-service — clinical/EHR core (patients & per-patient record).
# Copy to .env.local for local overrides. Defaults target the dev stack.

ENVIRONMENT=development
LOG_LEVEL=INFO

# Auth (Keycloak realm)
AUTH_ISSUER=http://localhost:8088/realms/medical-dictation
AUTH_JWKS_URL=http://localhost:8088/realms/medical-dictation/protocol/openid-connect/certs
AUTH_AUDIENCE=mdx-api

# CORS — SPA dev origins
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:4173,http://127.0.0.1:4173

# DB (RLS app role + audit writer)
DB_APP_ROLE_DSN=postgresql://app_role:app_role@localhost:5432/medical_dictation
DB_AUDIT_WRITER_DSN=postgresql://audit_writer:audit_writer@localhost:5432/medical_dictation

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
