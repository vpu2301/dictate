                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Rotate refresh cookie; return a new access token",
        "tags": [
          "auth"
        ]
      }
    },
    "/healthz": {
      "get": {
        "operationId": "healthz_healthz_get",
