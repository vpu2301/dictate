    "/audit/events": {
      "get": {
        "description": "Paginated, filtered read of audit.events for the caller's tenant.\n\nPagination cursor is the last seq seen. Pass it as ``cursor`` on the\nnext call to fetch events with ``seq > cursor``. Combined with\n``limit`` this gives stable forward-only paging without skipped rows.",
        "operationId": "list_events_audit_events_get",
        "parameters": [
          {
            "description": "Min seq (inclusive)",
            "in": "query",
            "name": "from_seq",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "minimum": 1,
                  "type": "integer"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Min seq (inclusive)",
              "title": "From Seq"
            }
          },
          {
            "description": "Max seq (inclusive)",
            "in": "query",
            "name": "to_seq",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "minimum": 1,
                  "type": "integer"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Max seq (inclusive)",
              "title": "To Seq"
            }
          },
          {
            "description": "Exact kind match",
            "in": "query",
            "name": "kind",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Exact kind match",
              "title": "Kind"
            }
          },
          {
            "description": "Filter by actor UUID",
            "in": "query",
            "name": "actor_sub",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "format": "uuid",
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Filter by actor UUID",
              "title": "Actor Sub"
            }
          },
          {
            "description": "created_at >= since",
            "in": "query",
            "name": "since",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "format": "date-time",
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "description": "created_at >= since",
              "title": "Since"
            }
          },
          {
            "description": "created_at <= until",
            "in": "query",
            "name": "until",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "format": "date-time",
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "description": "created_at <= until",
              "title": "Until"
            }
          },
          {
            "description": "info | warn | sec | error",
            "in": "query",
            "name": "severity",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "description": "info | warn | sec | error",
              "title": "Severity"
            }
          },
          {
            "in": "query",
            "name": "limit",
            "required": false,
            "schema": {
              "default": 100,
              "maximum": 500,
              "minimum": 1,
              "title": "Limit",
              "type": "integer"
            }
          },
          {
            "description": "Resume from seq > cursor",
            "in": "query",
            "name": "cursor",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "minimum": 1,
                  "type": "integer"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Resume from seq > cursor",
              "title": "Cursor"
            }
          },
          {
            "in": "header",
            "name": "Authorization",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Authorization"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": true,
                  "title": "Response List Events Audit Events Get",
                  "type": "object"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "List audit events for the caller's tenant",
        "tags": [
          "audit"
        ]
      }
    },
    "/audit/verify": {
      "get": {
        "description": "Walk the chain, recompute every hash, and report the first divergence\n(if any). Returns ``ok``, ``events_checked``, ``last_seq``/``last_hash``,\nand on failure ``first_divergence_seq`` + ``divergence_reason`` +\n``expected_hash``/``actual_hash``.",
        "operationId": "verify_chain_audit_verify_get",
        "parameters": [
          {
            "in": "query",
            "name": "from_seq",
            "required": false,
            "schema": {
              "default": 1,
              "minimum": 1,
              "title": "From Seq",
              "type": "integer"
            }
          },
          {
            "in": "query",
            "name": "to_seq",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "minimum": 1,
                  "type": "integer"
                },
                {
                  "type": "null"
                }
              ],
              "title": "To Seq"
            }
          },
          {
            "in": "header",
            "name": "Authorization",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Authorization"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": true,
                  "title": "Response Verify Chain Audit Verify Get",
                  "type": "object"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Verify the audit chain for the caller's tenant",
        "tags": [
          "audit"
        ]
      }
    },
    "/auth/login": {
      "post": {
        "operationId": "login_auth_login_post",
