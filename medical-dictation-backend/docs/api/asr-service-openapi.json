{
  "components": {
    "schemas": {
      "Body_submit_job_asr_jobs_post": {
        "properties": {
          "audio": {
            "contentMediaType": "application/octet-stream",
            "description": "Audio file to transcribe.",
            "title": "Audio",
            "type": "string"
          },
          "encounter_id": {
            "anyOf": [
              {
                "format": "uuid",
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Encounter Id"
          },
          "language": {
            "pattern": "^(uk|en)$",
            "title": "Language",
            "type": "string"
          },
          "prompt_id": {
            "format": "uuid",
            "title": "Prompt Id",
            "type": "string"
          }
        },
        "required": [
          "audio",
          "prompt_id",
          "language"
        ],
        "title": "Body_submit_job_asr_jobs_post",
        "type": "object"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "title": "Detail",
            "type": "array"
          }
        },
        "title": "HTTPValidationError",
        "type": "object"
      },
      "HealthResponse": {
        "properties": {
          "status": {
            "title": "Status",
            "type": "string"
          }
        },
        "required": [
          "status"
        ],
        "title": "HealthResponse",
        "type": "object"
      },
      "JobResultView": {
        "description": "Pre-signed result fetch for a COMPLETE job.\n\nReturned by ``GET /asr/jobs/{id}/result``. The dedicated endpoint exists so\na client can fetch the (short-TTL) URL without polling the whole job view,\nand so \"not ready yet\" is an explicit 409 rather than a 200 with a null URL.",
        "properties": {
          "expires_in": {
            "title": "Expires In",
            "type": "integer"
          },
          "job_id": {
            "format": "uuid",
            "title": "Job Id",
            "type": "string"
          },
          "presigned_url": {
            "title": "Presigned Url",
            "type": "string"
          }
        },
        "required": [
          "job_id",
          "presigned_url",
          "expires_in"
        ],
        "title": "JobResultView",
        "type": "object"
      },
      "JobStatus": {
        "enum": [
          "queued",
          "running",
          "complete",
          "failed",
          "cancelled"
        ],
        "title": "JobStatus",
        "type": "string"
      },
      "PromptSummary": {
        "additionalProperties": false,
        "properties": {
          "id": {
            "format": "uuid",
            "title": "Id",
            "type": "string"
          },
          "is_default": {
            "title": "Is Default",
            "type": "boolean"
          },
          "language": {
            "title": "Language",
            "type": "string"
          },
          "specialty": {
            "title": "Specialty",
            "type": "string"
          }
        },
        "required": [
          "id",
          "language",
          "specialty",
          "is_default"
        ],
        "title": "PromptSummary",
        "type": "object"
      },
      "ReadyResponse": {
        "properties": {
          "db": {
            "title": "Db",
            "type": "string"
          },
          "redis": {
            "title": "Redis",
            "type": "string"
          },
          "s3": {
            "title": "S3",
            "type": "string"
          },
          "status": {
            "title": "Status",
            "type": "string"
          }
        },
        "required": [
          "status",
          "db",
          "redis",
          "s3"
        ],
        "title": "ReadyResponse",
        "type": "object"
      },
      "TranscriptionJobView": {
        "description": "Public view of a transcription job. Returned by the GET endpoints.",
        "properties": {
          "attempts": {
            "default": 0,
            "title": "Attempts",
            "type": "integer"
          },
          "audio_id": {
            "format": "uuid",
            "title": "Audio Id",
            "type": "string"
          },
          "error_detail": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Error Detail"
          },
          "error_kind": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Error Kind"
          },
          "finished_at": {
            "anyOf": [
              {
                "format": "date-time",
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Finished At"
          },
          "id": {
            "format": "uuid",
            "title": "Id",
            "type": "string"
          },
          "language": {
            "title": "Language",
            "type": "string"
          },
          "model": {
            "title": "Model",
            "type": "string"
          },
          "prompt_id": {
            "format": "uuid",
            "title": "Prompt Id",
            "type": "string"
          },
          "queued_at": {
            "format": "date-time",
            "title": "Queued At",
            "type": "string"
          },
          "requester_sub": {
            "format": "uuid",
            "title": "Requester Sub",
            "type": "string"
          },
          "result_url": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Result Url"
          },
          "started_at": {
            "anyOf": [
              {
                "format": "date-time",
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Started At"
          },
          "status": {
            "$ref": "#/components/schemas/JobStatus"
          },
          "tenant_id": {
            "format": "uuid",
            "title": "Tenant Id",
            "type": "string"
          }
        },
        "required": [
          "id",
          "tenant_id",
          "audio_id",
          "requester_sub",
          "prompt_id",
          "language",
          "model",
          "status",
          "queued_at"
        ],
        "title": "TranscriptionJobView",
        "type": "object"
      },
      "ValidationError": {
        "properties": {
          "ctx": {
            "title": "Context",
            "type": "object"
          },
          "input": {
            "title": "Input"
          },
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "title": "Location",
            "type": "array"
          },
          "msg": {
            "title": "Message",
            "type": "string"
          },
          "type": {
            "title": "Error Type",
            "type": "string"
          }
        },
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError",
        "type": "object"
      }
