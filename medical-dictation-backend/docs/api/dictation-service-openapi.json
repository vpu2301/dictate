{
  "openapi": "3.1.0",
  "info": {
    "title": "Dictation Service",
    "description": "Sprint-04 streaming ASR. HTTP companion endpoints alongside the medical-dictation.v1 WebSocket protocol (docs/api/dictation-ws-v1.md).",
    "version": "0.4.0"
  },
  "paths": {
    "/healthz": {
      "get": {
        "tags": ["health"],
        "summary": "Liveness probe",
        "operationId": "healthz_healthz_get",
        "responses": {"200": {"description": "OK"}}
      }
    },
    "/readyz": {
      "get": {
        "tags": ["health"],
        "summary": "Readiness probe (DB, Redis, Whisper, GPU)",
        "operationId": "readyz_readyz_get",
        "responses": {
          "200": {"description": "ready"},
          "503": {"description": "not ready"}
        }
      }
    },
    "/dictate/sessions/{session_id}": {
      "get": {
        "tags": ["dictate"],
        "summary": "Fetch a session detail + transcript",
        "parameters": [
          {"name": "session_id", "in": "path", "required": true, "schema": {"type": "string", "format": "uuid"}}
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {"application/json": {"schema": {"$ref": "#/components/schemas/SessionDetail"}}}
          },
          "404": {"description": "Not found"}
        }
      }
    },
    "/dictate/sessions": {
      "get": {
        "tags": ["dictate"],
        "summary": "List recent sessions for the caller (or filtered by status).",
        "parameters": [
          {"name": "limit", "in": "query", "schema": {"type": "integer", "minimum": 1, "maximum": 200, "default": 50}},
          {"name": "status", "in": "query", "schema": {"$ref": "#/components/schemas/SessionStatus"}}
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {"$ref": "#/components/schemas/SessionSummary"}
                }
              }
            }
          }
        }
      }
    },
    "/dictate/sessions/{session_id}/finalize": {
      "post": {
        "tags": ["dictate"],
        "summary": "Force-finalize a stuck reconnecting session.",
        "parameters": [
          {"name": "session_id", "in": "path", "required": true, "schema": {"type": "string", "format": "uuid"}}
        ],
        "responses": {
          "202": {"description": "finalized"},
          "404": {"description": "Not found / not owned by caller"},
          "409": {"description": "Session is already terminal"}
        }
      }
    }
  },
  "components": {
    "schemas": {
      "SessionStatus": {
        "type": "string",
        "enum": ["creating", "active", "paused", "reconnecting", "finalized", "abandoned", "failed"]
      },
      "SessionSummary": {
        "type": "object",
        "required": ["id", "status", "language", "target_kind", "last_active_at"],
        "properties": {
          "id": {"type": "string", "format": "uuid"},
          "status": {"$ref": "#/components/schemas/SessionStatus"},
          "language": {"type": "string"},
          "target_kind": {"type": "string"},
          "started_at": {"type": "string", "format": "date-time", "nullable": true},
          "last_active_at": {"type": "string", "format": "date-time"},
          "finalized_at": {"type": "string", "format": "date-time", "nullable": true},
          "total_audio_ms": {"type": "integer", "default": 0},
          "network_drop_count": {"type": "integer", "default": 0}
        }
      },
      "SessionDetail": {
        "type": "object",
        "required": [
          "id", "tenant_id", "user_id", "status", "language",
          "target_kind", "prompt_id", "transcript", "total_audio_ms",
          "network_drop_count", "last_active_at"
        ],
        "properties": {
          "id": {"type": "string", "format": "uuid"},
          "tenant_id": {"type": "string", "format": "uuid"},
          "user_id": {"type": "string", "format": "uuid"},
          "status": {"$ref": "#/components/schemas/SessionStatus"},
          "language": {"type": "string"},
          "target_kind": {"type": "string"},
          "prompt_id": {"type": "string", "format": "uuid"},
          "transcript": {"type": "array", "items": {"type": "object", "additionalProperties": true}},
          "total_audio_ms": {"type": "integer"},
          "avg_partial_latency_ms": {"type": "integer", "nullable": true},
          "avg_final_latency_ms": {"type": "integer", "nullable": true},
          "network_drop_count": {"type": "integer"},
          "started_at": {"type": "string", "format": "date-time", "nullable": true},
          "last_active_at": {"type": "string", "format": "date-time"},
          "finalized_at": {"type": "string", "format": "date-time", "nullable": true}
        }
      }
    }
  }
}
