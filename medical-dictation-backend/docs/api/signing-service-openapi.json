    "/signing/sessions/{session_id}": {
      "delete": {
        "description": "Cancel an in-flight signing session (M1\u00b7B2).\n\nCancellable only from {initiating, awaiting_user}; never once the\ndocument is verifying/signed. The optimistic ``transition_session``\nraces cleanly against ``jobs/reaper.py`` \u2014 if the session has already\nmoved on, the transition no-ops and we return 409.",
        "operationId": "cancel_session_signing_sessions__session_id__delete",
        "parameters": [
          {
            "in": "path",
            "name": "session_id",
            "required": true,
            "schema": {
              "format": "uuid",
              "title": "Session Id",
