{
  "title": "Sprint 06 — Templates",
  "schemaVersion": 39,
  "version": 1,
  "tags": ["sprint-06", "templates"],
  "timezone": "browser",
  "refresh": "30s",
  "time": {"from": "now-3h", "to": "now"},
  "panels": [
    {
      "type": "stat",
      "title": "Template cache hit ratio",
      "id": 1,
      "gridPos": {"h": 4, "w": 8, "x": 0, "y": 0},
      "targets": [{
        "expr": "sum(rate(mdx_template_cache_hits_total[5m])) / (sum(rate(mdx_template_cache_hits_total[5m])) + sum(rate(mdx_template_cache_misses_total[5m])))"
      }],
      "fieldConfig": {"defaults": {"thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "yellow", "value": 0.5}, {"color": "green", "value": 0.8}]}}}
    },
    {
      "type": "timeseries",
      "title": "Clones / Updates / Deprecations per minute",
      "id": 2,
      "gridPos": {"h": 8, "w": 16, "x": 8, "y": 0},
      "targets": [
        {"expr": "sum(rate(mdx_template_clones_total[1m])) * 60", "legendFormat": "clones"},
        {"expr": "sum(rate(mdx_template_updates_total[1m])) * 60", "legendFormat": "updates"},
        {"expr": "sum(rate(mdx_template_deprecations_total[1m])) * 60", "legendFormat": "deprecations"}
      ]
    },
    {
      "type": "timeseries",
      "title": "Section switch rate",
      "id": 3,
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "targets": [
        {"expr": "sum by (reason) (rate(mdx_dictation_section_switches_total[5m]))", "legendFormat": "{{reason}}"}
      ]
    },
    {
      "type": "timeseries",
      "title": "Section switch latency p95 (ms)",
      "id": 4,
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "targets": [
        {"expr": "histogram_quantile(0.95, sum by (le) (rate(mdx_dictation_section_switch_latency_ms_bucket[5m])))", "legendFormat": "p95"},
        {"expr": "200", "legendFormat": "alert threshold"}
      ]
    },
    {
      "type": "timeseries",
      "title": "Section prompt lookups (cache hot path)",
      "id": 5,
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 16},
      "targets": [
        {"expr": "sum(rate(mdx_template_section_prompt_lookups_total[1m])) * 60", "legendFormat": "lookups/min"}
      ]
    }
  ]
}
