{
  "title": "Sprint 02 — Auth & Audit",
  "uid": "sprint-02-auth-audit",
  "tags": ["sprint-02", "auth", "audit", "security"],
  "schemaVersion": 39,
  "timezone": "browser",
  "refresh": "30s",
  "time": {"from": "now-1h", "to": "now"},
  "templating": {
    "list": [
      {
        "name": "tenant",
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "query": "label_values(mdx_audit_chain_depth, tenant_id)",
        "includeAll": true,
        "multi": true,
        "current": {"text": "All", "value": "$__all"}
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Login rate / s",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 0, "w": 12, "h": 6},
      "targets": [
        {
          "expr": "sum by (result) (rate(mdx_auth_login_total[1m]))",
          "legendFormat": "{{result}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "reqps"}, "overrides": []}
    },
    {
      "id": 2,
      "title": "Login failure rate / s, by reason",
      "type": "timeseries",
      "gridPos": {"x": 12, "y": 0, "w": 12, "h": 6},
      "targets": [
        {
          "expr": "sum by (result) (rate(mdx_auth_login_total{result!=\"success\"}[1m]))",
          "legendFormat": "{{result}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Refresh-token replay rate (target: 0)",
      "type": "stat",
      "gridPos": {"x": 0, "y": 6, "w": 6, "h": 4},
      "targets": [
        {"expr": "sum(increase(mdx_auth_refresh_replay_total[5m]))", "refId": "A"}
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "green", "value": null}, {"color": "red", "value": 1}
          ]}
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "title": "JWKS cache hit ratio",
      "type": "stat",
      "gridPos": {"x": 6, "y": 6, "w": 6, "h": 4},
      "targets": [
        {
          "expr": "sum(rate(mdx_jwks_cache_hits_total[5m])) / clamp_min(sum(rate(mdx_jwks_cache_hits_total[5m])) + sum(rate(mdx_jwks_cache_misses_total[5m])), 1)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "red", "value": null}, {"color": "yellow", "value": 0.9}, {"color": "green", "value": 0.95}
          ]}
        },
        "overrides": []
      }
    },
    {
      "id": 5,
      "title": "Audit write latency p50/p95/p99",
      "type": "timeseries",
      "gridPos": {"x": 12, "y": 6, "w": 12, "h": 6},
      "targets": [
        {"expr": "histogram_quantile(0.5, sum by (le) (rate(mdx_audit_write_duration_seconds_bucket[5m])))", "legendFormat": "p50", "refId": "A"},
        {"expr": "histogram_quantile(0.95, sum by (le) (rate(mdx_audit_write_duration_seconds_bucket[5m])))", "legendFormat": "p95", "refId": "B"},
        {"expr": "histogram_quantile(0.99, sum by (le) (rate(mdx_audit_write_duration_seconds_bucket[5m])))", "legendFormat": "p99", "refId": "C"}
      ],
      "fieldConfig": {"defaults": {"unit": "s"}, "overrides": []}
    },
    {
      "id": 6,
      "title": "Audit chain depth, by tenant",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 12, "w": 12, "h": 6},
      "targets": [
        {
          "expr": "mdx_audit_chain_depth{tenant_id=~\"$tenant\"}",
          "legendFormat": "{{tenant_id}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "title": "Audit chain verify status",
      "type": "stat",
      "gridPos": {"x": 12, "y": 12, "w": 6, "h": 6},
      "targets": [{"expr": "min(mdx_audit_chain_ok)", "refId": "A"}],
      "fieldConfig": {
        "defaults": {
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "red", "value": null}, {"color": "green", "value": 1}
          ]}
        },
        "overrides": []
      }
    },
    {
      "id": 8,
      "title": "Authz denials (sec events)",
      "type": "timeseries",
      "gridPos": {"x": 18, "y": 12, "w": 6, "h": 6},
      "targets": [
        {
          "expr": "sum by (action, target_kind) (rate(mdx_authz_denied_total[5m]))",
          "legendFormat": "{{action}}/{{target_kind}}",
          "refId": "A"
        }
      ]
    }
  ]
}
